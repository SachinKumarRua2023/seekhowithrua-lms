{
  "version": 2,
  "name": "seekhowithrua-lms",
  "buildCommand": null,
  "outputDirectory": "frontend",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
